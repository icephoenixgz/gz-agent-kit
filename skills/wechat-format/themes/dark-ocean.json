    "callout_title": {
      "font_weight": "600",
      "color": "#38bdf8",
      "margin_bottom": "8px",
      "font_size": "15px"
    },
    "callout_content": {
      "font_size": "15px",
      "color": "#7dd3fc",
      "line_height": "1.7"
