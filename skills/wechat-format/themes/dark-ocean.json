      "align_items": "center",
      "justify_content": "center",
      "width": "22px",
      "height": "22px",
      "min_width": "22px",
      "background": "rgba(56,189,248,0.15)",
      "color": "#38bdf8",
      "border_radius": "50%",
      "font_size": "13px",
      "font_weight": "600",
      "margin_right": "10px",
      "margin_top": "4px"
