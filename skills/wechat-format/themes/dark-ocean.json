    "callout": {
      "background": "rgba(56,189,248,0.06)",
      "border_left": "3px solid #38bdf8",
      "padding": "14px 18px",
      "margin_top": "18px",
      "margin_bottom": "18px",
      "border_radius": "0 10px 10px 0"
