    "accent": "#38bdf8",
    "background": "#0f172a",
    "blockquote_bg": "rgba(56,189,248,0.06)",
    "code_bg": "#0f172a",
    "hr_color": "#1e3a5f",
    "footnote_bg": "rgba(56,189,248,0.03)"
  },
  "layout": "hero",
