{
  "name": "星空黑金",
  "description": "深空冷峻神秘：深空紫黑 #0B0118 + 金色 #E6B800 细字 + 冷紫点缀。H1 金色字距 8px 居中+金细线、H2 金边框+内嵌小字、blockquote 左金线+深紫底、hr 金渐变。神秘冷峻派（vs night-read 温暖书房派，vs cyber-neon 霓虹派）。适合哲学/玄幻/科幻/冥想/神秘主义。",
  "source": "https://github.com/GordenSun/WX",
  "colors": {"primary":"#E8E0FF","accent":"#E6B800","background":"#0B0118","blockquote_bg":"rgba(230,184,0,0.06)","code_bg":"rgba(230,184,0,0.12)","hr_color":"#E6B800","footnote_bg":"rgba(230,184,0,0.04)"},
  "styles": {
    "wrapper": {"background_color":"#0B0118","padding":"28px 20px","font_family":"'Cormorant Garamond','Baskerville','Songti SC','PingFang SC',serif"},
    "h1": {"font_size":"26px","font_weight":"400","color":"#E6B800","text_align":"center","line_height":"1.4","margin_top":"42px","margin_bottom":"32px","padding":"16px 0","border_top":"1px solid #E6B800","border_bottom":"1px solid #E6B800","letter_spacing":"8px","text_transform":"uppercase"},
    "h2": {"font_size":"19px","font_weight":"500","font_style":"italic","color":"#E6B800","line_height":"1.45","margin_top":"36px","margin_bottom":"18px","padding":"6px 16px","border":"1px solid rgba(230,184,0,0.5)","display":"inline-block","letter_spacing":"3px"},
    "h3": {"font_size":"17px","font_weight":"500","font_style":"italic","color":"#E8E0FF","line_height":"1.5","margin_top":"28px","margin_bottom":"14px","letter_spacing":"2px"},
    "h4": {"font_size":"14px","font_weight":"600","color":"#E6B800","line_height":"1.55","margin_top":"22px","margin_bottom":"10px","letter_spacing":"3px","text_transform":"uppercase"},
    "h5": {"font_size":"14px","font_weight":"500","color":"#C9B8FF","margin_top":"18px","margin_bottom":"8px","line_height":"1.55","font_style":"italic"},
    "h6": {"font_size":"12px","font_weight":"500","color":"#8A7BB0","margin_top":"16px","margin_bottom":"6px","line_height":"1.55","letter_spacing":"2px","text_transform":"uppercase"},
    "p": {"font_size":"15px","color":"#E8E0FF","line_height":"2","margin_top":"0","margin_bottom":"18px","letter_spacing":"0.5px","text_align":"justify"},
    "blockquote": {"background":"rgba(230,184,0,0.06)","border_left":"1px solid #E6B800","padding":"16px 22px","border_radius":"0","margin_top":"26px","margin_bottom":"26px","font_size":"15px","color":"#C9B8FF","line_height":"1.9","font_style":"italic","letter_spacing":"0.8px"},
    "blockquote_p": {"font_size":"15px","color":"#C9B8FF","line_height":"1.9","margin_bottom":"0","letter_spacing":"0.8px","background":"transparent","font_style":"italic"},
    "strong": {"font_weight":"700","color":"#E6B800"},
    "em": {"font_style":"italic","color":"#D4B8FF"},
    "a": {"color":"#E6B800","text_decoration":"none","border_bottom":"1px solid #E6B800","padding_bottom":"1px"},
    "img": {"max_width":"100%","display":"block","margin_top":"22px","margin_bottom":"10px","border":"1px solid #E6B800","padding":"6px","background":"rgba(11,1,24,0.8)"},
    "img_wrapper": {"background":"transparent","padding":"0","margin_top":"22px","margin_bottom":"22px"},
    "hr": {"margin_top":"38px","margin_bottom":"38px","height":"1px","border":"none","background":"linear-gradient(90deg,transparent,#E6B800,transparent)"},
    "code": {"background":"rgba(230,184,0,0.12)","padding":"1px 6px","border_radius":"2px","font_size":"90%","color":"#E6B800","font_family":"'Cormorant Garamond',Georgia,serif","font_style":"italic"},
    "code_block": {"background":"#070011","border":"1px solid rgba(230,184,0,0.4)","border_radius":"0","margin_top":"24px","margin_bottom":"24px","overflow":"hidden"},
    "code_header": {"display":"flex","align_items":"center","height":"30px","padding":"0 14px","background":"rgba(230,184,0,0.15)","color":"#E6B800","font_size":"11px","letter_spacing":"2.5px","text_transform":"uppercase","font_style":"italic"},
    "pre": {"background":"#070011","color":"#E8E0FF","padding":"14px 16px","overflow_x":"auto","margin_top":"0","margin_bottom":"0","font_size":"12px","line_height":"1.75","white_space":"pre-wrap"},
    "pre_code": {"background":"none","padding":"0","color":"#E8E0FF","font_size":"12px","font_family":"'SF Mono',Menlo,monospace"},
    "table": {"width":"100%","border_collapse":"collapse","margin_top":"22px","margin_bottom":"22px","font_size":"14px","border":"1px solid rgba(230,184,0,0.4)"},
    "th": {"padding":"10px 12px","text_align":"left","font_weight":"500","color":"#0B0118","background":"#E6B800","font_style":"italic","letter_spacing":"1.5px"},
    "td": {"padding":"8px 12px","border_bottom":"1px solid rgba(230,184,0,0.15)","color":"#E8E0FF"},
    "list_item_bullet": {"color":"#E6B800","margin_right":"10px","font_weight":"500","font_style":"italic"},
    "ol_item_bullet": {"color":"#E6B800","font_weight":"500","margin_right":"10px","font_style":"italic"},
    "list_item_text": {"font_size":"15px","color":"#E8E0FF","line_height":"2","letter_spacing":"0.5px"},
    "list_wrapper": {"margin_top":"14px","margin_bottom":"14px"},
    "list_item_row": {"display":"flex","margin_bottom":"8px","align_items":"flex-start"}
  }
}
