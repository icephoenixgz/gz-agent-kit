{
  "name": "北欧冷白",
  "description": "北欧极简冷调：#F5F7FA 冷灰白 + #0EA5E9 冷蓝 + Inter sans + 超大留白。H1 小号 22px 左靠瘦字，H2 细线底，p 行距 2，整体呼吸感极大（vs swiss-grid 硬朗压字距派，本主题是纤细纤柔派）。适合极简生活/设计思考/产品评测/书摘。",
  "source": "https://github.com/GordenSun/WX",
  "colors": {"primary":"#1E293B","accent":"#0EA5E9","background":"#F5F7FA","blockquote_bg":"#E0F2FE","code_bg":"#E2E8F0","hr_color":"#CBD5E1","footnote_bg":"#F1F5F9"},
  "styles": {
    "wrapper": {"background_color":"#F5F7FA","padding":"36px 22px","font_family":"'Inter','Helvetica Neue','PingFang SC',-apple-system,sans-serif"},
    "h1": {"font_size":"22px","font_weight":"600","color":"#1E293B","line_height":"1.3","margin_top":"48px","margin_bottom":"30px","letter_spacing":"-0.01em"},
    "h2": {"font_size":"20px","font_weight":"600","color":"#1E293B","line_height":"1.4","margin_top":"40px","margin_bottom":"16px","padding_bottom":"10px","border_bottom":"1px solid #CBD5E1","letter_spacing":"0.5px"},
    "h3": {"font_size":"15px","font_weight":"600","color":"#0EA5E9","line_height":"1.5","margin_top":"28px","margin_bottom":"12px"},
    "h4": {"font_size":"14px","font_weight":"600","color":"#1E293B","line_height":"1.5","margin_top":"22px","margin_bottom":"10px"},
    "h5": {"font_size":"13px","font_weight":"500","color":"#64748B","margin_top":"18px","margin_bottom":"8px","line_height":"1.5"},
    "h6": {"font_size":"11px","font_weight":"500","color":"#94A3B8","margin_top":"16px","margin_bottom":"6px","line_height":"1.5","letter_spacing":"1.5px","text_transform":"uppercase"},
    "p": {"font_size":"15px","color":"#334155","line_height":"2","margin_top":"0","margin_bottom":"20px","letter_spacing":"0.1px"},
    "blockquote": {"background":"#E0F2FE","border_left":"2px solid #0EA5E9","padding":"16px 20px","border_radius":"0 4px 4px 0","margin_top":"28px","margin_bottom":"28px","font_size":"14px","color":"#475569","line_height":"1.85"},
    "blockquote_p": {"font_size":"14px","color":"#475569","line_height":"1.85","margin_bottom":"0","background":"transparent"},
    "strong": {"font_weight":"600","color":"#0EA5E9"},
    "em": {"font_style":"italic","color":"#64748B"},
    "a": {"color":"#0EA5E9","text_decoration":"none","border_bottom":"1px solid #0EA5E9","padding_bottom":"1px"},
    "img": {"max_width":"100%","display":"block","margin_top":"24px","margin_bottom":"10px","border_radius":"2px"},
    "img_wrapper": {"background":"transparent","padding":"0","margin_top":"24px","margin_bottom":"24px"},
    "hr": {"margin_top":"44px","margin_bottom":"44px","height":"1px","border":"none","background":"#CBD5E1"},
    "code": {"background":"#E2E8F0","padding":"1px 6px","border_radius":"3px","font_size":"88%","color":"#0EA5E9","font_family":"'JetBrains Mono','SF Mono',Menlo,monospace"},
    "code_block": {"background":"#FFFFFF","border":"1px solid #E2E8F0","border_radius":"4px","margin_top":"24px","margin_bottom":"24px","overflow":"hidden"},
    "code_header": {"display":"flex","align_items":"center","height":"30px","padding":"0 14px","background":"#F1F5F9","color":"#64748B","font_size":"11px","letter_spacing":"1px"},
    "pre": {"background":"#FFFFFF","color":"#1E293B","padding":"14px 16px","overflow_x":"auto","margin_top":"0","margin_bottom":"0","font_size":"12px","line_height":"1.7","white_space":"pre-wrap"},
    "pre_code": {"background":"none","padding":"0","color":"#1E293B","font_size":"12px","font_family":"'JetBrains Mono','SF Mono',Menlo,monospace"},
    "table": {"width":"100%","border_collapse":"collapse","margin_top":"22px","margin_bottom":"22px","font_size":"13px"},
    "th": {"padding":"10px 12px","text_align":"left","font_weight":"600","color":"#1E293B","background":"#F1F5F9","border_bottom":"1px solid #CBD5E1","font_size":"11px","letter_spacing":"1px","text_transform":"uppercase"},
    "td": {"padding":"10px 12px","border_bottom":"1px solid #E2E8F0","color":"#334155"},
    "list_item_bullet": {"color":"#0EA5E9","margin_right":"10px","font_weight":"600"},
    "ol_item_bullet": {"color":"#0EA5E9","font_weight":"600","margin_right":"10px"},
    "list_item_text": {"font_size":"15px","color":"#334155","line_height":"2"},
    "list_wrapper": {"margin_top":"16px","margin_bottom":"16px"},
    "list_item_row": {"display":"flex","margin_bottom":"8px","align_items":"flex-start"}
  }
}
