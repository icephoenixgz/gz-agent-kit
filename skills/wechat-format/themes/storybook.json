{
  "name": "童书彩虹",
  "description": "童书插画感：奶白 #FFFDF2 + 多彩四色（粉 #FF9AA2/桃 #FFB7B2/芒果 #FFDAC1/薄荷 #B5EAD7/天蓝 #C7CEEA）循环。H1 粉色大胶囊+白字、H2 桃色方块、H3 薄荷绿左条、blockquote 芒果底+天蓝字、hr 彩虹条。亲子童真派（vs pastel 单一柔紫，vs memphis 锋利跳跃）。适合儿童教育/育儿/亲子/轻松随笔。",
  "source": "https://github.com/GordenSun/WX",
  "colors": {"primary":"#3A3A3A","accent":"#FF9AA2","background":"#FFFDF2","blockquote_bg":"#FFDAC1","code_bg":"#FFE5E5","hr_color":"#FF9AA2","footnote_bg":"rgba(181,234,215,0.15)"},
  "styles": {
    "wrapper": {"background_color":"#FFFDF2","padding":"26px 20px","font_family":"'Quicksand','Nunito','PingFang SC','Hiragino Sans GB',sans-serif"},
    "h1": {"font_size":"26px","font_weight":"700","color":"#FFFFFF","text_align":"center","line_height":"1.4","margin_top":"36px","margin_bottom":"28px","padding":"18px 30px","background":"linear-gradient(135deg,#FF9AA2 0%,#FFB7B2 100%)","border_radius":"999px","letter_spacing":"2px","box_shadow":"0 8px 24px rgba(255,154,162,0.35)"},
    "h2": {"font_size":"20px","font_weight":"700","color":"#FFFFFF","line_height":"1.4","margin_top":"30px","margin_bottom":"16px","padding":"8px 18px","background":"#FFB7B2","border_radius":"14px","display":"inline-block","letter_spacing":"1px","box_shadow":"0 4px 12px rgba(255,183,178,0.30)"},
    "h3": {"font_size":"17px","font_weight":"700","color":"#3A3A3A","line_height":"1.5","margin_top":"26px","margin_bottom":"12px","padding":"4px 0 4px 14px","border_left":"6px solid #B5EAD7","background":"rgba(181,234,215,0.20)","border_radius":"0 8px 8px 0"},
    "h4": {"font_size":"15px","font_weight":"700","color":"#C7CEEA","line_height":"1.5","margin_top":"22px","margin_bottom":"10px","letter_spacing":"0.5px"},
    "h5": {"font_size":"14px","font_weight":"600","color":"#6A6A6A","margin_top":"18px","margin_bottom":"8px","line_height":"1.5"},
    "h6": {"font_size":"12px","font_weight":"600","color":"#999999","margin_top":"16px","margin_bottom":"6px","line_height":"1.5","letter_spacing":"1.5px"},
    "p": {"font_size":"16px","color":"#3A3A3A","line_height":"1.9","margin_top":"0","margin_bottom":"16px","letter_spacing":"0.3px"},
    "blockquote": {"background":"#FFDAC1","padding":"16px 22px","border_radius":"16px","margin_top":"24px","margin_bottom":"24px","font_size":"15px","color":"#6A4A3A","line_height":"1.8","border_left":"none","box_shadow":"inset 4px 0 0 #C7CEEA"},
    "blockquote_p": {"font_size":"15px","color":"#6A4A3A","line_height":"1.8","margin_bottom":"0","background":"transparent"},
    "strong": {"font_weight":"700","color":"#FFFFFF","background":"#FF9AA2","padding":"1px 6px","border_radius":"6px"},
    "em": {"font_style":"italic","color":"#C7CEEA","font_weight":"600"},
    "a": {"color":"#FF9AA2","text_decoration":"none","background":"linear-gradient(180deg,rgba(255,154,162,0) 70%,rgba(255,218,193,0.6) 70%)","padding":"0 3px"},
    "img": {"max_width":"100%","display":"block","margin_top":"20px","margin_bottom":"10px","border_radius":"20px","box_shadow":"0 10px 30px rgba(255,154,162,0.2)"},
    "img_wrapper": {"background":"transparent","padding":"0","margin_top":"20px","margin_bottom":"20px"},
    "hr": {"margin_top":"32px","margin_bottom":"32px","height":"6px","border":"none","background":"linear-gradient(90deg,#FF9AA2 0 20%,#FFDAC1 20% 40%,#FFD700 40% 60%,#B5EAD7 60% 80%,#C7CEEA 80% 100%)","border_radius":"3px"},
    "code": {"background":"#FFE5E5","padding":"2px 8px","border_radius":"8px","font_size":"92%","color":"#FF9AA2","font_family":"'SF Mono','Menlo',monospace","font_weight":"600"},
    "code_block": {"background":"#FFFFFF","border":"2px solid #B5EAD7","border_radius":"16px","margin_top":"22px","margin_bottom":"22px","overflow":"hidden","box_shadow":"0 6px 18px rgba(181,234,215,0.25)"},
    "code_header": {"display":"flex","align_items":"center","height":"32px","padding":"0 16px","background":"#B5EAD7","color":"#3A3A3A","font_size":"12px","font_weight":"700","letter_spacing":"1px"},
    "pre": {"background":"#FFFFFF","color":"#3A3A3A","padding":"14px 18px","overflow_x":"auto","margin_top":"0","margin_bottom":"0","font_size":"13px","line_height":"1.7","white_space":"pre-wrap"},
    "pre_code": {"background":"none","padding":"0","color":"#3A3A3A","font_size":"13px","font_family":"'SF Mono','Menlo',monospace"},
    "table": {"width":"100%","border_collapse":"separate","border_spacing":"0","margin_top":"20px","margin_bottom":"20px","font_size":"14px","border_radius":"14px","overflow":"hidden","box_shadow":"0 6px 16px rgba(255,154,162,0.12)"},
    "th": {"padding":"12px 14px","text_align":"left","font_weight":"700","color":"#FFFFFF","background":"#FF9AA2"},
    "td": {"padding":"10px 14px","border_bottom":"1px solid #FFF0E8","color":"#3A3A3A","background":"#FFFFFF"},
    "list_item_bullet": {"color":"#FFFFFF","background":"#FF9AA2","margin_right":"10px","font_weight":"700","padding":"0 6px","border_radius":"50%","font_size":"12px"},
    "ol_item_bullet": {"display":"inline-flex","align_items":"center","justify_content":"center","width":"24px","height":"24px","min_width":"24px","background":"linear-gradient(135deg,#B5EAD7,#C7CEEA)","color":"#3A3A3A","border_radius":"50%","font_size":"13px","font_weight":"700","margin_right":"10px","margin_top":"2px"},
    "list_item_text": {"font_size":"16px","color":"#3A3A3A","line_height":"1.9"},
    "list_wrapper": {"margin_top":"14px","margin_bottom":"14px"},
    "list_item_row": {"display":"flex","margin_bottom":"8px","align_items":"flex-start"}
  }
}
