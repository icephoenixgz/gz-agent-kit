{
  "name": "学术论文",
  "description": "学术期刊严肃感：纯白 + Times New Roman + 超小字 12-13px + 行距 1.7 + italic H3 + 超细分章节。H1 16px uppercase 纯黑、H2 14px italic 编号感、H3 13px italic 缩进、p 12px 首行缩进 2em 两端对齐、blockquote 左双线内嵌。论文派严肃（vs broadsheet 报刊密集派，vs newspaper 新闻派）。适合研究报告/深度分析/综述/严肃评论。",
  "source": "https://github.com/GordenSun/WX",
  "colors": {
    "primary": "#0F0F0F",
    "accent": "#1A3A6E",
    "background": "#FFFFFF",
    "blockquote_bg": "transparent",
    "code_bg": "#F5F5F5",
    "hr_color": "#0F0F0F",
    "footnote_bg": "#FAFAFA"
  },
  "styles": {
    "wrapper": {
      "background_color": "#FFFFFF",
      "padding": "30px 22px",
      "font_family": "'Times New Roman','Times','Songti SC','PingFang SC',serif"
    },
    "h1": {
      "font_size": "28px",
      "font_weight": "700",
      "color": "#0F0F0F",
      "text_align": "center",
      "line_height": "1.3",
      "margin_top": "36px",
      "margin_bottom": "26px",
      "letter_spacing": "1px"
    },
    "h2": {
      "font_size": "20px",
      "font_weight": "700",
      "font_style": "italic",
      "color": "#0F0F0F",
      "line_height": "1.4",
      "margin_top": "32px",
      "margin_bottom": "14px",
      "letter_spacing": "0.5px"
    },
    "h3": {
      "font_size": "17px",
      "font_weight": "700",
      "font_style": "italic",
      "color": "#1A3A6E",
      "line_height": "1.45",
      "margin_top": "24px",
      "margin_bottom": "10px",
      "padding_left": "16px"
    },
    "h4": {
      "font_size": "15px",
      "font_weight": "700",
      "color": "#0F0F0F",
      "line_height": "1.45",
      "margin_top": "20px",
      "margin_bottom": "8px",
      "padding_left": "24px"
    },
    "h5": {
      "font_size": "14px",
      "font_weight": "600",
      "color": "#333333",
      "margin_top": "16px",
      "margin_bottom": "6px",
      "line_height": "1.45",
      "padding_left": "24px"
    },
    "h6": {
      "font_size": "13px",
      "font_weight": "600",
      "color": "#666666",
      "margin_top": "14px",
      "margin_bottom": "6px",
      "line_height": "1.45"
    },
    "p": {
      "font_size": "16px",
      "color": "#0F0F0F",
      "line_height": "1.75",
      "margin_top": "0",
      "margin_bottom": "16px",
      "text_align": "justify",
      "text_indent": "2em",
      "letter_spacing": "0.3px"
    },
    "blockquote": {
      "border_left": "3px double #0F0F0F",
      "padding": "4px 16px",
      "margin": "18px 30px",
      "font_size": "12px",
      "color": "#333333",
      "line_height": "1.7",
      "background": "transparent",
      "text_align": "justify"
    },
    "blockquote_p": {
      "font_size": "12px",
      "color": "#333333",
      "line_height": "1.7",
      "margin_bottom": "0",
      "background": "transparent",
      "text_indent": "0"
    },
    "strong": {
      "font_weight": "700",
      "color": "#0F0F0F"
    },
    "em": {
      "font_style": "italic",
      "color": "#1A3A6E"
    },
    "a": {
      "color": "#1A3A6E",
      "text_decoration": "none",
      "font_style": "italic"
    },
    "img": {
      "max_width": "100%",
      "display": "block",
      "margin_top": "18px",
      "margin_bottom": "6px",
      "border": "1px solid #CCCCCC"
    },
    "img_wrapper": {
      "background": "transparent",
      "padding": "0",
      "margin_top": "18px",
      "margin_bottom": "18px"
    },
    "hr": {
      "margin_top": "24px",
      "margin_bottom": "24px",
      "height": "0",
      "border": "none",
      "border_top": "1px solid #0F0F0F",
      "width": "40px",
      "margin_left": "auto",
      "margin_right": "auto"
    },
    "code": {
      "background": "#F5F5F5",
      "padding": "1px 4px",
      "border_radius": "2px",
      "font_size": "88%",
      "color": "#1A3A6E",
      "font_family": "'Courier New','SF Mono',monospace"
    },
    "code_block": {
      "background": "#FAFAFA",
      "border": "1px solid #DDDDDD",
      "border_radius": "0",
      "margin_top": "18px",
      "margin_bottom": "18px",
      "overflow": "hidden"
    },
    "code_header": {
      "display": "flex",
      "align_items": "center",
      "height": "24px",
      "padding": "0 10px",
      "background": "#EEEEEE",
      "color": "#666666",
      "font_size": "10px",
      "font_style": "italic"
    },
    "pre": {
      "background": "#FAFAFA",
      "color": "#0F0F0F",
      "padding": "10px 12px",
      "overflow_x": "auto",
      "margin_top": "0",
      "margin_bottom": "0",
      "font_size": "11px",
      "line_height": "1.65",
      "white_space": "pre-wrap"
    },
    "pre_code": {
      "background": "none",
      "padding": "0",
      "color": "#0F0F0F",
      "font_size": "11px",
      "font_family": "'Courier New','SF Mono',monospace"
    },
    "table": {
      "width": "100%",
      "border_collapse": "collapse",
      "margin_top": "16px",
      "margin_bottom": "16px",
      "font_size": "12px"
    },
    "th": {
      "padding": "6px 10px",
      "text_align": "left",
      "font_weight": "700",
      "color": "#0F0F0F",
      "background": "transparent",
      "border_top": "2px solid #0F0F0F",
      "border_bottom": "1px solid #0F0F0F",
      "font_style": "italic"
    },
    "td": {
      "padding": "6px 10px",
      "border_bottom": "1px solid #DDDDDD",
      "color": "#0F0F0F"
    },
    "list_item_bullet": {
      "color": "#0F0F0F",
      "margin_right": "8px",
      "font_weight": "700",
      "font_size": "10px"
    },
    "ol_item_bullet": {
      "color": "#1A3A6E",
      "font_weight": "700",
      "margin_right": "8px",
      "font_style": "italic"
    },
    "list_item_text": {
      "font_size": "16px",
      "color": "#0F0F0F",
      "line_height": "1.75",
      "letter_spacing": "0.3px"
    },
    "list_wrapper": {
      "margin_top": "10px",
      "margin_bottom": "10px"
    },
    "list_item_row": {
      "display": "flex",
      "margin_bottom": "4px",
      "align_items": "flex-start"
    }
  }
}