{
  "name": "便签鸭黄",
  "description": "便利贴手写感：鸭黄底 #FFF8B8 + 橙红 #FF6B35 + 棕字 + Caveat 手写字体。H1 大字随意、H2 橙色手写、blockquote 像便条手写附注、wrapper 带单边阴影模拟翘角贴纸。轻快随性独一份（vs pastel 柔紫圆润）。适合备忘录/灵感手记/吐槽/轻快评论。",
  "source": "https://github.com/GordenSun/WX",
  "colors": {
    "primary": "#4A3628",
    "accent": "#FF6B35",
    "background": "#FFF8B8",
    "blockquote_bg": "#FFFAD4",
    "code_bg": "#FFE8C0",
    "hr_color": "#FF6B35",
    "footnote_bg": "rgba(255,107,53,0.05)"
  },
  "styles": {
    "wrapper": {
      "background_color": "#FFF8B8",
      "padding": "26px 18px",
      "font_family": "'Caveat','Marker Felt','Comic Sans MS','Hiragino Sans GB','PingFang SC',cursive",
      "box_shadow": "6px 6px 0 rgba(0,0,0,0.10)"
    },
    "h1": {
      "font_size": "34px",
      "font_weight": "700",
      "color": "#4A3628",
      "text_align": "left",
      "line_height": "1.2",
      "margin_top": "28px",
      "margin_bottom": "22px",
      "padding_bottom": "10px",
      "border_bottom": "3px wavy #FF6B35",
      "letter_spacing": "1px",
      "font_family": "'Caveat','Marker Felt',cursive",
      "transform": "rotate(-0.5deg)"
    },
    "h2": {
      "font_size": "26px",
      "font_weight": "700",
      "color": "#FF6B35",
      "line_height": "1.25",
      "margin_top": "26px",
      "margin_bottom": "14px",
      "font_family": "'Caveat','Marker Felt',cursive"
    },
    "h3": {
      "font_size": "22px",
      "font_weight": "600",
      "color": "#4A3628",
      "line_height": "1.3",
      "margin_top": "22px",
      "margin_bottom": "10px",
      "padding_left": "14px",
      "border_left": "4px solid #FF6B35",
      "font_family": "'Caveat','Marker Felt',cursive"
    },
    "h4": {
      "font_size": "19px",
      "font_weight": "600",
      "color": "#FF6B35",
      "line_height": "1.4",
      "margin_top": "18px",
      "margin_bottom": "8px",
      "font_style": "italic",
      "font_family": "'Caveat',cursive"
    },
    "h5": {
      "font_size": "18px",
      "font_weight": "600",
      "color": "#6A5238",
      "margin_top": "16px",
      "margin_bottom": "8px",
      "line_height": "1.4",
      "font_family": "'Caveat',cursive"
    },
    "h6": {
      "font_size": "16px",
      "font_weight": "600",
      "color": "#8A7656",
      "margin_top": "14px",
      "margin_bottom": "6px",
      "line_height": "1.4",
      "font_family": "'Caveat',cursive"
    },
    "p": {
      "font_size": "17px",
      "color": "#4A3628",
      "line_height": "1.7",
      "margin_top": "0",
      "margin_bottom": "16px",
      "letter_spacing": "0.3px"
    },
    "blockquote": {
      "background": "#FFFAD4",
      "border": "2px dashed #FF6B35",
      "padding": "14px 18px",
      "border_radius": "4px",
      "margin_top": "20px",
      "margin_bottom": "20px",
      "font_size": "18px",
      "color": "#6A5238",
      "line_height": "1.65",
      "transform": "rotate(-0.3deg)",
      "box_shadow": "3px 3px 0 rgba(0,0,0,0.08)"
    },
    "blockquote_p": {
      "font_size": "18px",
      "color": "#6A5238",
      "line_height": "1.65",
      "margin_bottom": "0",
      "background": "transparent"
    },
    "strong": {
      "font_weight": "700",
      "color": "#FF6B35",
      "background": "linear-gradient(180deg,rgba(255,107,53,0) 60%,rgba(255,107,53,0.25) 60%)"
    },
    "em": {
      "font_style": "italic",
      "color": "#6A5238"
    },
    "a": {
      "color": "#FF6B35",
      "text_decoration": "underline",
      "text_decoration_style": "wavy",
      "text_underline_offset": "3px"
    },
    "img": {
      "max_width": "100%",
      "display": "block",
      "margin_top": "18px",
      "margin_bottom": "8px",
      "border": "3px solid #4A3628",
      "padding": "6px",
      "background": "#FFFFFF",
      "box_shadow": "4px 4px 0 #FF6B35",
      "transform": "rotate(-1deg)"
    },
    "img_wrapper": {
      "background": "transparent",
      "padding": "0",
      "margin_top": "18px",
      "margin_bottom": "18px"
    },
    "hr": {
      "margin_top": "30px",
      "margin_bottom": "30px",
      "height": "0",
      "border": "none",
      "border_top": "3px dashed #FF6B35",
      "width": "60%",
      "margin_left": "auto",
      "margin_right": "auto"
    },
    "code": {
      "background": "#FFE8C0",
      "padding": "2px 8px",
      "border_radius": "10px",
      "font_size": "16px",
      "color": "#4A3628",
      "font_family": "'Caveat','Marker Felt',cursive",
      "font_weight": "600"
    },
    "code_block": {
      "background": "#FFFAD4",
      "border": "2px solid #4A3628",
      "border_radius": "6px",
      "margin_top": "22px",
      "margin_bottom": "22px",
      "overflow": "hidden",
      "box_shadow": "4px 4px 0 #FF6B35"
    },
    "code_header": {
      "display": "flex",
      "align_items": "center",
      "height": "32px",
      "padding": "0 14px",
      "background": "#FF6B35",
      "color": "#FFF8B8",
      "font_size": "14px",
      "font_weight": "700",
      "font_family": "'Caveat',cursive"
    },
    "pre": {
      "background": "#FFFAD4",
      "color": "#4A3628",
      "padding": "12px 16px",
      "overflow_x": "auto",
      "margin_top": "0",
      "margin_bottom": "0",
      "font_size": "13px",
      "line_height": "1.65",
      "white_space": "pre-wrap",
      "font_family": "'SF Mono',Menlo,monospace"
    },
    "pre_code": {
      "background": "none",
      "padding": "0",
      "color": "#4A3628",
      "font_size": "13px",
      "font_family": "'SF Mono',Menlo,monospace"
    },
    "table": {
      "width": "100%",
      "border_collapse": "collapse",
      "margin_top": "18px",
      "margin_bottom": "18px",
      "font_size": "16px",
      "border": "2px solid #4A3628"
    },
    "th": {
      "padding": "10px 12px",
      "text_align": "left",
      "font_weight": "700",
      "color": "#FFF8B8",
      "background": "#FF6B35",
      "font_size": "17px"
    },
    "td": {
      "padding": "8px 12px",
      "border_bottom": "2px dashed #FFDA8A",
      "color": "#4A3628"
    },
    "list_item_bullet": {
      "color": "#FF6B35",
      "margin_right": "10px",
      "font_weight": "700"
    },
    "ol_item_bullet": {
      "color": "#FF6B35",
      "font_weight": "700",
      "margin_right": "10px",
      "font_size": "20px"
    },
    "list_item_text": {
      "font_size": "19px",
      "color": "#4A3628",
      "line_height": "1.7"
    },
    "list_wrapper": {
      "margin_top": "14px",
      "margin_bottom": "14px"
    },
    "list_item_row": {
      "display": "flex",
      "margin_bottom": "8px",
      "align_items": "flex-start"
    }
  },
  "lint": {
    "display_type": true
  }
}
