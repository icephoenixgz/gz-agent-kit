{
  "name": "数据简报",
  "description": "报告蓝 #0F4C81 + 琥珀点缀，深底反白表头，为数据密集型内容设计：日报、榜单、模型对比",
  "colors": {
    "primary": "#1F2937",
    "accent": "#0F4C81",
    "background": "#ffffff",
    "blockquote_bg": "#F1F5F9",
    "code_bg": "#F8FAFC",
    "hr_color": "#0F4C81",
    "footnote_bg": "#F8FAFC"
  },
  "styles": {
    "wrapper": {
      "background_color": "#ffffff",
      "padding": "16px"
    },
    "h1": {
      "font_size": "24px",
      "font_weight": "800",
      "color": "#ffffff",
      "text_align": "left",
      "background": "#0F4C81",
      "border_left": "6px solid #F59E0B",
      "border_radius": "4px",
      "padding": "14px 18px",
      "margin_top": "24px",
      "margin_bottom": "16px",
      "line_height": "1.3",
      "letter_spacing": "1px"
    },
    "h2": {
      "display": "flex",
      "align_items": "center",
      "border_bottom": "3px solid #0F4C81",
      "padding": "0 0 8px 0",
      "margin": "36px 0 14px",
      "line_height": "1.3"
    },
    "h2_prefix": {
      "display": "inline-block",
      "background": "#F59E0B",
      "color": "#ffffff",
      "font_size": "14px",
      "font_weight": "800",
      "padding": "2px 8px",
      "border_radius": "4px",
      "margin_right": "10px",
      "letter_spacing": "1px",
      "line_height": "1.5"
    },
    "h2_inner": {
      "display": "inline-block",
      "font_size": "20px",
      "font_weight": "bold",
      "color": "#111827",
      "letter_spacing": "0.5px"
    },
    "h3": {
      "font_size": "17px",
      "font_weight": "bold",
      "color": "#0F4C81",
      "border_left": "4px solid #F59E0B",
      "padding": "0 0 0 10px",
      "margin_top": "28px",
      "margin_bottom": "10px",
      "line_height": "1.3"
    },
    "h4": {
      "font_size": "16px",
      "font_weight": "bold",
      "color": "#1F2937",
      "padding": "0",
      "margin_top": "24px",
      "margin_bottom": "8px",
      "line_height": "1.3"
    },
    "h5": {
      "font_size": "15px",
      "font_weight": "bold",
      "color": "#374151",
      "padding": "0",
      "margin_top": "20px",
      "margin_bottom": "6px",
      "line_height": "1.3"
    },
    "h6": {
      "font_size": "15px",
      "font_weight": "bold",
      "color": "#6B7280",
      "padding": "0",
      "margin_top": "16px",
      "margin_bottom": "6px",
      "line_height": "1.3"
    },
    "p": {
      "font_size": "16px",
      "color": "#2D3748",
      "line_height": "1.78",
      "margin_top": "0",
      "margin_bottom": "20px",
      "letter_spacing": "0.5px",
      "text_align": "justify"
    },
    "blockquote": {
      "border_left": "4px solid #0F4C81",
      "background": "#F1F5F9",
      "padding": "14px 16px",
      "margin_top": "24px",
      "margin_bottom": "24px",
      "border_radius": "0 6px 6px 0",
      "font_size": "15px",
      "color": "#334155",
      "line_height": "1.75"
    },
    "blockquote_p": {
      "font_size": "15px",
      "color": "#334155",
      "line_height": "1.75",
      "margin_bottom": "0",
      "letter_spacing": "0.3px",
      "font_style": "normal",
      "background": "transparent"
    },
    "strong": {
      "font_weight": "bold",
      "color": "#0F4C81"
    },
    "em": {
      "font_style": "normal",
      "font_weight": "bold",
      "color": "#B45309"
    },
    "a": {
      "color": "#0F4C81",
      "text_decoration": "none",
      "border_bottom": "1px solid rgba(15,76,129,0.3)"
    },
    "img": {
      "max_width": "100%",
      "border_radius": "6px",
      "display": "block",
      "box_shadow": "0 2px 10px rgba(15,76,129,0.1)"
    },
    "img_wrapper": {
      "background": "#ffffff",
      "border_radius": "8px",
      "padding": "2px",
      "margin_top": "12px",
      "margin_bottom": "12px"
    },
    "hr": {
      "margin_top": "32px",
      "margin_bottom": "32px",
      "height": "2px",
      "background": "linear-gradient(to right, #0F4C81, #F59E0B)",
      "border": "none"
    },
    "code": {
      "background": "rgba(15,76,129,0.08)",
      "padding": "3px 6px",
      "border_radius": "4px",
      "font_size": "90%",
      "color": "#0F4C81",
      "font_family": "Menlo, Monaco, Consolas, 'Courier New', monospace"
    },
    "code_block": {
      "background": "#F8FAFC",
      "border_radius": "6px",
      "margin_top": "24px",
      "margin_bottom": "24px",
      "overflow": "hidden",
      "border": "1px solid #E2E8F0",
      "border_top": "3px solid #0F4C81"
    },
    "code_header": {
      "display": "flex",
      "align_items": "center",
      "height": "36px",
      "padding": "0 12px",
      "background": "#EFF3F8"
    },
    "pre": {
      "background": "#F8FAFC",
      "color": "#1E293B",
      "padding": "20px",
      "border_radius": "0",
      "overflow_x": "auto",
      "margin_top": "0",
      "margin_bottom": "0",
      "font_size": "14px",
      "line_height": "1.6",
      "white_space": "pre-wrap",
      "word_wrap": "break-word",
      "word_break": "break-all"
    },
    "pre_code": {
      "background": "none",
      "padding": "0",
      "color": "#1E293B",
      "font_size": "14px",
      "font_family": "Menlo, Monaco, Consolas, 'Courier New', monospace"
    },
    "table": {
      "width": "100%",
      "border_collapse": "separate",
      "margin_top": "16px",
      "margin_bottom": "20px",
      "font_size": "14px",
      "border_spacing": "0",
      "border_radius": "6px",
      "overflow": "hidden",
      "border": "1px solid #E2E8F0"
    },
    "th": {
      "background": "#0F4C81",
      "padding": "10px 12px",
      "border": "none",
      "text_align": "left",
      "font_weight": "bold",
      "color": "#ffffff",
      "letter_spacing": "0.5px"
    },
    "td": {
      "padding": "9px 12px",
      "border_bottom": "1px solid #EDF2F7",
      "color": "#2D3748"
    },
    "list_item_bullet": {
      "color": "#F59E0B",
      "margin_right": "8px",
      "font_weight": "bold"
    },
    "ol_item_bullet": {
      "display": "inline-flex",
      "align_items": "center",
      "justify_content": "center",
      "width": "22px",
      "height": "22px",
      "min_width": "22px",
      "background": "#0F4C81",
      "color": "#ffffff",
      "border_radius": "4px",
      "font_size": "13px",
      "font_weight": "bold",
      "margin_right": "10px",
      "margin_top": "4px"
    },
    "list_item_text": {
      "font_size": "16px",
      "color": "#2D3748",
      "line_height": "1.78",
      "letter_spacing": "0.5px"
    },
    "list_wrapper": {
      "margin_top": "15px",
      "margin_bottom": "15px"
    },
    "list_item_row": {
      "display": "flex",
      "margin_bottom": "8px",
      "align_items": "flex-start"
    },
    "footnote_section": {
      "margin_top": "32px",
      "padding_top": "16px",
      "border_top": "2px solid #0F4C81"
    },
    "footnote_title": {
      "font_size": "14px",
      "font_weight": "bold",
      "color": "#64748B",
      "margin_bottom": "12px"
    },
    "footnote_item": {
      "font_size": "13px",
      "color": "#64748B",
      "margin_bottom": "6px",
      "line_height": "1.6",
      "word_break": "break-all"
    },
    "footnote_sup": {
      "font_size": "12px",
      "color": "#0F4C81",
      "vertical_align": "super",
      "margin_left": "2px"
    },
    "callout": {
      "background": "rgba(15,76,129,0.06)",
      "border_left": "4px solid #0F4C81",
      "padding": "16px",
      "margin_top": "16px",
      "margin_bottom": "16px",
      "border_radius": "0 6px 6px 0"
    },
    "callout_title": {
      "font_weight": "bold",
      "color": "#0F4C81",
      "margin_bottom": "8px",
      "font_size": "15px"
    },
    "callout_content": {
      "font_size": "14px",
      "color": "#334155",
      "line_height": "1.75",
      "letter_spacing": "0.3px"
    }
  },
  "decor": {
    "h2": {
      "prefix_text": "{n}"
    }
  },
  "dark_mode": {
    "wrapper": {
      "bgcolor": "#16181D"
    },
    "h1": {
      "bgcolor": "#143D66",
      "color": "#ffffff"
    },
    "h2_inner": {
      "color": "#E5E7EB"
    },
    "h2_prefix": {
      "bgcolor": "#B45309",
      "color": "#ffffff"
    },
    "h3": {
      "color": "#7FB3E0"
    },
    "blockquote": {
      "bgcolor": "rgba(255,255,255,0.05)"
    },
    "code_block": {
      "bgcolor": "#1E1E1E"
    },
    "code_header": {
      "bgcolor": "#171717"
    },
    "pre": {
      "bgcolor": "#1E1E1E",
      "color": "#d4d4d4"
    },
    "pre_code": {
      "color": "#d4d4d4"
    },
    "code": {
      "bgcolor": "#2a2a2a",
      "color": "#7FB3E0"
    },
    "img_wrapper": {
      "bgcolor": "#262626"
    },
    "th": {
      "bgcolor": "#143D66"
    },
    "callout": {
      "bgcolor": "rgba(15,76,129,0.18)"
    },
    "ol_item_bullet": {
      "bgcolor": "#143D66"
    }
  }
}
