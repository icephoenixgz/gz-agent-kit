      "padding_bottom": "8px",
      "border_bottom": "2px solid #79FFE1",
      "letter_spacing": "4px",
      "text_transform": "uppercase"
    },
    "h3": {
      "font_size": "18px",
      "font_weight": "600",
      "color": "#FF6AD5",
      "line_height": "1.5",
      "margin_top": "26px",
      "margin_bottom": "12px",
      "letter_spacing": "3px",
      "text_transform": "uppercase"
    },
    "h4": {
      "font_size": "15px",
      "font_weight": "600",
      "color": "#C4A0E8",
      "line_height": "1.55",
      "margin_top": "22px",
      "margin_bottom": "10px",
      "letter_spacing": "2px"
    },
    "h5": {
      "font_size": "14px",
      "font_weight": "600",
      "color": "#79FFE1",
      "margin_top": "18px",
      "margin_bottom": "8px",
      "line_height": "1.55",
      "letter_spacing": "1.5px"
    },
    "h6": {
      "font_size": "12px",
      "font_weight": "600",
      "color": "#8B7BA8",
      "margin_top": "16px",
      "margin_bottom": "6px",
      "line_height": "1.55",
      "letter_spacing": "1.5px",
      "text_transform": "uppercase"
    },
    "p": {
      "font_size": "15px",
      "color": "#E8DAFB",
      "line_height": "1.85",
      "margin_top": "0",
      "margin_bottom": "16px",
      "letter_spacing": "0.4px"
    },
    "blockquote": {
      "background": "rgba(255,106,213,0.10)",
      "border_left": "4px solid #79FFE1",
      "padding": "14px 18px",
      "border_radius": "0",
      "margin_top": "22px",
      "margin_bottom": "22px",
      "font_size": "15px",
      "color": "#FFCCEE",
      "line_height": "1.8",
      "letter_spacing": "0.5px"
    },
    "blockquote_p": {
      "font_size": "15px",
      "color": "#FFCCEE",
      "line_height": "1.8",
      "margin_bottom": "0",
      "letter_spacing": "0.5px",
      "background": "transparent"
    },
    "strong": {
      "font_weight": "700",
      "color": "#79FFE1",
      "text_shadow": "0 0 6px rgba(121,255,225,0.5)"
    },
    "em": {
      "font_style": "italic",
      "color": "#FF6AD5"
    },
    "a": {
      "color": "#79FFE1",
      "text_decoration": "underline",
      "text_underline_offset": "3px"
    },
    "img": {
      "max_width": "100%",
      "display": "block",
      "margin_top": "18px",
      "margin_bottom": "8px",
      "border": "2px solid #FF6AD5",
