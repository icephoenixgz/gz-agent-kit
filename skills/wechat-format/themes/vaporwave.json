      "margin_bottom": "34px",
      "height": "2px",
      "border": "none",
      "background": "linear-gradient(90deg,transparent,#FF6AD5 30%,#79FFE1 70%,transparent)"
    },
    "code": {
      "background": "rgba(121,255,225,0.12)",
      "padding": "1px 6px",
      "border_radius": "0",
      "font_size": "92%",
      "color": "#79FFE1",
      "font_family": "'VT323','SF Mono',Menlo,monospace"
    },
    "code_block": {
      "background": "#0D0620",
      "border": "2px solid #FF6AD5",
      "border_radius": "0",
      "margin_top": "22px",
      "margin_bottom": "22px",
      "overflow": "hidden",
      "box_shadow": "6px 6px 0 #79FFE1"
    },
    "code_header": {
      "display": "flex",
      "align_items": "center",
      "height": "30px",
      "padding": "0 14px",
      "background": "#FF6AD5",
      "color": "#1A0D2E",
      "font_size": "11px",
      "font_weight": "700",
      "letter_spacing": "2px",
      "text_transform": "uppercase"
    },
    "pre": {
      "background": "#0D0620",
      "color": "#79FFE1",
      "padding": "14px 16px",
      "overflow_x": "auto",
      "margin_top": "0",
      "margin_bottom": "0",
      "font_size": "13px",
      "line_height": "1.7",
      "white_space": "pre-wrap"
    },
    "pre_code": {
      "background": "none",
      "padding": "0",
      "color": "#79FFE1",
      "font_size": "13px",
      "font_family": "'VT323','SF Mono',Menlo,monospace"
    },
    "table": {
      "width": "100%",
      "border_collapse": "collapse",
      "margin_top": "20px",
      "margin_bottom": "20px",
      "font_size": "14px",
      "border": "2px solid #FF6AD5"
    },
    "th": {
      "padding": "10px 12px",
      "text_align": "left",
      "font_weight": "700",
      "color": "#1A0D2E",
      "background": "#FF6AD5",
      "letter_spacing": "1.5px",
      "text_transform": "uppercase",
      "font_size": "12px"
    },
    "td": {
      "padding": "10px 12px",
      "border_bottom": "1px solid rgba(255,106,213,0.25)",
      "color": "#E8DAFB"
    },
    "list_item_bullet": {
      "color": "#FF6AD5",
      "margin_right": "10px",
      "font_weight": "700"
    },
    "ol_item_bullet": {
      "color": "#79FFE1",
      "font_weight": "700",
      "margin_right": "10px"
    },
    "list_item_text": {
      "font_size": "15px",
      "color": "#E8DAFB",
      "line_height": "1.85",
      "letter_spacing": "0.4px"
    },
    "list_wrapper": {
      "margin_top": "14px",
      "margin_bottom": "14px"
    },
    "list_item_row": {
      "display": "flex",
      "margin_bottom": "6px",
      "align_items": "flex-start"
    }
  },
  "lint": {
    "display_type": true
  }
}
