{
  "name": "蒸汽波",
  "description": "80s 梦幻蒸汽波美学：深紫底 #1A0D2E + 霓粉 #FF6AD5 + 水蓝 #79FFE1 双亮色。H1 霓粉超大 uppercase 10px 字距 + text-shadow 发光、H2 水蓝带下划、blockquote 霓粉柔底 + 水蓝左条、全局 font 等宽混搭。retro future 复古未来。适合 AI 艺术/赛博哲思/亚文化/电子音乐评论。",
  "source": "https://github.com/GordenSun/WX",
  "colors": {
    "primary": "#E8DAFB",
    "accent": "#FF6AD5",
    "background": "#1A0D2E",
    "blockquote_bg": "rgba(255,106,213,0.10)",
    "code_bg": "rgba(121,255,225,0.12)",
    "hr_color": "#FF6AD5",
    "footnote_bg": "rgba(255,106,213,0.04)"
  },
  "styles": {
    "wrapper": {
      "background_color": "#1A0D2E",
      "padding": "26px 18px",
      "font_family": "'VT323','Courier New','SF Mono','PingFang SC',monospace"
    },
    "h1": {
      "font_size": "34px",
      "font_weight": "700",
      "color": "#FF6AD5",
      "text_align": "center",
      "line_height": "1.25",
      "margin_top": "40px",
      "margin_bottom": "28px",
      "letter_spacing": "10px",
      "text_transform": "uppercase",
      "text_shadow": "3px 3px 0 #79FFE1, 0 0 20px rgba(255,106,213,0.6)"
    },
    "h2": {
      "font_size": "22px",
      "font_weight": "700",
      "color": "#79FFE1",
